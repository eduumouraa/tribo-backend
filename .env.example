# ══════════════════════════════════════════════════════════════════
# .env.example — Copie para .env e preencha os valores
# NUNCA commite o .env no Git!
# ══════════════════════════════════════════════════════════════════

# ── Banco de Dados ────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/tribo
DB_USER=tribo
DB_PASSWORD=tribo

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
JWT_SECRET=GERE_UMA_CHAVE_FORTE_AQUI

# ── Stripe ────────────────────────────────────────────────────────
# Dashboard do Stripe → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
# Dashboard do Stripe → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs dos produtos criados no Stripe
STRIPE_PRODUCT_TRIBO=prod_...
STRIPE_PRODUCT_FINANCAS=prod_...

# ── Panda Video ───────────────────────────────────────────────────
# Dashboard do Panda Video → Configurações → API
PANDA_VIDEO_API_KEY=...

# ── AWS (fase 2 — quando migrar do Panda para S3) ─────────────────
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=tribo-videos

# ── Email ─────────────────────────────────────────────────────────
MAIL_HOST=email-smtp.sa-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@triboinvest.com.br

# ── App ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080

# ── Cookies (auth) ────────────────────────────────────────────────
# true em produção (HTTPS obrigatório), false em dev local (HTTP)
APP_COOKIE_SECURE=true

# ── Observabilidade ───────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
ENVIRONMENT=production
APP_VERSION=1.0.0
SWAGGER_ENABLED=false
